<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cron Job: Process Recurring Donations -->
    <record id="ir_cron_process_recurring_donations" model="ir.cron">
        <field name="name">Process Recurring Donations</field>
        <field name="model_id" ref="model_donation_recurring_rule"/>
        <field name="state">code</field>
        <field name="code">model.action_process_recurring_donations()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>