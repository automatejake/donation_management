<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="donation_form_page" name="Donation Form">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <section class="s_donation_form py-5">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-8">
                                <h1 class="text-center mb-4">Make a Donation</h1>

                                <t t-if="error">
                                    <div class="alert alert-danger" role="alert">
                                        <t t-if="error == 'invalid_amount'">Please enter a valid donation amount.</t>
                                        <t t-if="error == 'invalid_provider'">Please select a valid payment method.</t>
                                        <t t-if="error == 'invalid_payment_method'">Please select how you would like to pay.</t>
                                        <t t-if="error == 'invalid_token'">The saved payment method could not be used. Please choose another option.</t>
                                        <t t-if="error == 'invalid_category'">Please select a valid donation category.</t>
                                        <t t-if="error == 'invalid_frequency'">Please select a valid donation schedule.</t>
                                        <t t-if="error == 'missing_start_date'">Please choose a start date for your recurring donation.</t>
                                        <t t-if="error == 'invalid_start_date'">Please enter a valid start date.</t>
                                        <t t-if="error == 'no_payment_method'">This payment provider is not configured with any payment methods. Please contact the site administrator.</t>
                                        <t t-if="error == 'invalid_payment'">We could not process your payment. Please try again or pick another payment method.</t>
                                        <t t-if="error == 'access_denied'">Access denied to this donation.</t>
                                        <t t-else=""><t t-esc="error"/></t>
                                    </div>
                                </t>

                                <t t-if="success">
                                    <div class="alert alert-success" role="alert">
                                        Thank you for your donation!
                                    </div>
                                </t>

                                <div class="card shadow-sm">
                                    <div class="card-body p-4">
                                        <form action="/donate/submit" method="POST" class="donation-form"
                                              t-att-data-default-fee-percent="default_fee_percent"
                                              t-att-data-is-public="user._is_public() and '1' or '0'">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <input type="hidden" name="fee_percent" id="fee_percent"
                                                   t-att-value="default_fee_percent"/>

                                            <!-- Amount (first) -->
                                            <div class="donation-amount-section mb-4">
                                                <label for="amount" class="donation-amount-heading">Donation amount</label>
                                                <div class="donation-amount-box">
                                                    <span class="donation-amount-symbol" aria-hidden="true">$</span>
                                                    <input type="number" name="amount" id="amount"
                                                           class="donation-amount-input"
                                                           placeholder="0"
                                                           min="1" step="0.01"
                                                           inputmode="decimal"
                                                           autocomplete="off"
                                                           required="required"/>
                                                </div>
                                                <!-- <p class="donation-amount-hint mb-0">Enter the amount you wish to give.</p> -->
                                            </div>

                                            <!-- Donation category -->
                                            <div class="mb-4" t-if="categories">
                                                <label for="category_id" class="form-label fw-bold">Donation Category</label>
                                                <select name="category_id" id="category_id" class="form-select">
                                                    <option value="">General (no specific fund)</option>
                                                    <t t-foreach="categories" t-as="cat">
                                                        <option t-att-value="cat.id"><t t-esc="cat.name"/></option>
                                                    </t>
                                                </select>
                                                <small class="form-text text-muted">Categories are used for accounting and reporting.</small>
                                            </div>

                                            <!-- Campaign -->
                                            <div class="mb-4" t-if="campaigns">
                                                <label for="campaign_id" class="form-label">Support a Campaign (Optional)</label>
                                                <select name="campaign_id" id="campaign_id" class="form-select">
                                                    <option value="">General Donation</option>
                                                    <t t-foreach="campaigns" t-as="campaign">
                                                        <option t-att-value="campaign.id">
                                                            <t t-esc="campaign.name"/>
                                                            <t t-if="campaign.goal_amount">
                                                                - <t t-esc="campaign.total_raised" t-options="{'widget': 'monetary', 'display_currency': campaign.currency_id}"/>
                                                                of <t t-esc="campaign.goal_amount" t-options="{'widget': 'monetary', 'display_currency': campaign.currency_id}"/>
                                                            </t>
                                                        </option>
                                                    </t>
                                                </select>
                                            </div>

                                            <!-- Donation schedule -->
                                            <div class="mb-4">
                                                <label class="form-label fw-bold">Donation Schedule *</label>
                                                <div class="btn-group w-100 flex-wrap donation-schedule-buttons" role="group">
                                                    <input type="radio" class="btn-check" name="frequency" id="freq_one_time" value="one_time" autocomplete="off" checked="checked"/>
                                                    <label class="btn btn-outline-primary" for="freq_one_time">One Time</label>

                                                    <input type="radio" class="btn-check" name="frequency" id="freq_weekly" value="weekly" autocomplete="off"/>
                                                    <label class="btn btn-outline-primary" for="freq_weekly">Weekly</label>

                                                    <input type="radio" class="btn-check" name="frequency" id="freq_biweekly" value="biweekly" autocomplete="off"/>
                                                    <label class="btn btn-outline-primary" for="freq_biweekly">Bi-weekly</label>

                                                    <input type="radio" class="btn-check" name="frequency" id="freq_monthly" value="monthly" autocomplete="off"/>
                                                    <label class="btn btn-outline-primary" for="freq_monthly">Monthly</label>
                                                </div>
                                                <div id="recurring_start_options" class="mt-3" style="display: none;">
                                                    <label for="recurring_start_date" class="form-label">First charge date *</label>
                                                    <input type="date" name="recurring_start_date" id="recurring_start_date" class="form-control"/>
                                                    <small class="form-text text-muted" id="recurring_start_hint">
                                                        If you choose today, your donation is charged when you click Donate Now and the next charge follows your schedule.
                                                        For a future date, your payment method is saved now and the first charge happens on that date.
                                                    </small>
                                                </div>
                                            </div>

                                            <!-- Donor information -->
                                            <h5 class="mb-3">Your Information</h5>
                                            <t t-if="user._is_public()">
                                                <div class="mb-3">
                                                    <label for="name" class="form-label">Full Name *</label>
                                                    <input type="text" name="name" id="name" class="form-control" required="required"/>
                                                </div>
                                                <div class="mb-3">
                                                    <label for="email" class="form-label">Email *</label>
                                                    <input type="email" name="email" id="email" class="form-control" required="required"/>
                                                </div>
                                                <div class="mb-3">
                                                    <label for="phone" class="form-label">Phone (Optional)</label>
                                                    <input type="tel" name="phone" id="phone" class="form-control"/>
                                                </div>
                                            </t>
                                            <t t-else="">
                                                <div class="alert alert-info">
                                                    Donating as: <strong><t t-esc="user.partner_id.name"/></strong>
                                                    (<t t-esc="user.partner_id.email"/>)
                                                </div>
                                            </t>

                                            <div class="mb-3">
                                                <label for="purpose" class="form-label">Message or Purpose (Optional)</label>
                                                <textarea name="purpose" id="purpose" class="form-control" rows="3"
                                                          placeholder="Share why you're donating or leave a message..."></textarea>
                                            </div>

                                            <!-- Payment method -->
                                            <h5 class="mb-3">Payment Method</h5>
                                            <div class="donation-payment-methods mb-4" id="donation_payment_methods">
                                                <t t-if="payment_tokens">
                                                    <p class="donation-payment-section-label">Saved payment methods</p>
                                                    <t t-foreach="payment_tokens" t-as="token">
                                                        <label class="donation-payment-option" t-att-for="'payment_token_%s' % token.id">
                                                            <input type="radio"
                                                                   class="donation-payment-option-input"
                                                                   name="payment_method"
                                                                   t-att-id="'payment_token_%s' % token.id"
                                                                   t-att-value="'token_%s' % token.id"
                                                                   t-att-data-fee-percent="token.provider_id.get_donation_fee_coverage_percent()"
                                                                   t-att-checked="'checked' if token_index == 0 else None"
                                                                   required="required"/>
                                                            <span class="donation-payment-option-body">
                                                                <span class="donation-payment-option-title">
                                                                    <i class="fa fa-credit-card me-2 text-muted" aria-hidden="true"/>
                                                                    <t t-esc="token.display_name"/>
                                                                </span>
                                                                <span class="donation-payment-option-meta">
                                                                    <t t-esc="token.payment_method_id.name"/>
                                                                    · <t t-esc="token.provider_id.name"/>
                                                                </span>
                                                            </span>
                                                        </label>
                                                    </t>
                                                    <p class="donation-payment-section-label mt-3" t-if="providers">Or pay with a new method</p>
                                                </t>
                                                <div id="donation_saved_tokens_guest" class="mb-2" style="display: none;">
                                                    <p class="donation-payment-section-label">Saved payment methods</p>
                                                    <div id="donation_saved_tokens_list"/>
                                                </div>
                                                <t t-foreach="providers" t-as="provider">
                                                    <label class="donation-payment-option" t-att-for="'payment_provider_%s' % provider.id">
                                                        <input type="radio"
                                                               class="donation-payment-option-input"
                                                               name="payment_method"
                                                               t-att-id="'payment_provider_%s' % provider.id"
                                                               t-att-value="'provider_%s' % provider.id"
                                                               t-att-data-fee-percent="provider.get_donation_fee_coverage_percent()"
                                                               t-att-checked="'checked' if (not payment_tokens and provider_index == 0) else None"
                                                               required="required"/>
                                                        <span class="donation-payment-option-body">
                                                            <span class="donation-payment-option-title d-flex align-items-center gap-2">
                                                                <img t-if="provider.image_128"
                                                                     t-att-src="image_data_uri(provider.image_128)"
                                                                     class="donation-provider-logo"
                                                                     t-att-alt="provider.name"/>
                                                                <t t-esc="provider.name"/>
                                                            </span>
                                                            <span class="donation-payment-option-meta">
                                                                Processing fee if covered:
                                                                <t t-esc="'%.2f' % provider.get_donation_fee_coverage_percent()"/>%
                                                            </span>
                                                        </span>
                                                    </label>
                                                </t>
                                                <p t-if="not providers and not payment_tokens" class="text-muted mb-0">
                                                    No payment methods are available. Please contact us.
                                                </p>
                                            </div>
                                            <!-- Cover fees -->
                                            <div class="mb-4 border-top pt-3">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="cover_fees" name="cover_fees"/>
                                                    <label class="form-check-label" for="cover_fees">
                                                        I'd like to cover processing fees
                                                        (<span id="cover_fees_percent_label"><t t-esc="default_fee_percent"/></span>%)
                                                    </label>
                                                </div>
                                                <small id="cover_fees_summary" class="form-text text-muted" style="display: none;">
                                                    Total charge: <strong id="cover_fees_total">$0.00</strong>
                                                    (includes <span id="cover_fees_amount">$0.00</span> in fees)
                                                </small>
                                            </div>

                                            <div class="d-grid">
                                                <button type="submit" class="btn btn-primary btn-lg">
                                                    <i class="fa fa-heart me-2"></i> Donate Now
                                                </button>
                                            </div>

                                            <p class="text-muted text-center mt-3 small">
                                                Your donation is secure and processed through our trusted payment partners.
                                            </p>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- Payment Redirect Template -->
    <template id="donation_payment_redirect" name="Donation Payment Processing">
        <t t-call="website.layout">
            <div id="wrap">
                <div class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-8 text-center">
                            <h2 class="mb-4">Processing your donation</h2>
                            <p class="lead" t-if="redirect_form_html">
                                Please wait while we redirect you to the payment provider…
                            </p>

                            <t t-if="redirect_form_html">
                                <div id="o_donation_payment_redirect" t-out="redirect_form_html"/>
                                <script>
                                    document.addEventListener('DOMContentLoaded', function () {
                                        var root = document.getElementById('o_donation_payment_redirect');
                                        if (!root) { return; }
                                        var form = root.querySelector('form');
                                        if (form) { form.submit(); }
                                    });
                                </script>
                            </t>

                            <t t-if="demo_direct">
                                <p class="text-muted mb-4">
                                    This is the test payment provider. Choose a simulated outcome, then confirm.
                                </p>
                                <form action="/donate/demo/pay" method="post" class="text-start mx-auto" style="max-width: 520px;">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="tx_id" t-att-value="tx.id"/>
                                    <div class="row g-2">
                                        <div class="col-12 col-md-6">
                                            <label class="form-label small" for="customer_input">Payment details (test)</label>
                                            <input type="text" name="customer_input" id="customer_input" class="form-control"
                                                   placeholder="XXXX XXXX XXXX XXXX"/>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label small" for="simulated_state">Simulated result</label>
                                            <select name="simulated_state" id="simulated_state" class="form-select">
                                                <option value="done">Successful</option>
                                                <option value="pending">Pending</option>
                                                <option value="cancel">Cancelled</option>
                                                <option value="error">Error</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="d-grid mt-4">
                                        <button type="submit" class="btn btn-primary btn-lg">Pay now</button>
                                    </div>
                                </form>
                            </t>

                            <t t-if="not redirect_form_html and not demo_direct">
                                <div class="alert alert-warning">
                                    Payment could not be started for this provider configuration.
                                    Please try another payment method or contact support.
                                </div>
                                <a href="/donate" class="btn btn-secondary">Back to donation form</a>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Donation Confirmation Page -->
    <template id="donation_confirmation_page" name="Donation Confirmation">
        <t t-call="website.layout">
            <div id="wrap">
                <div class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-6 text-center">
                            <div class="mb-4">
                                <i class="fa fa-check-circle text-success" style="font-size: 72px;"></i>
                            </div>
                            <h1 class="mb-3">Thank You!</h1>
                            <p class="lead">Your donation has been received.</p>

                            <div class="card mt-4">
                                <div class="card-body">
                                    <h5 class="card-title">Donation Details</h5>
                                    <table class="table table-borderless">
                                        <tr>
                                            <td class="text-end"><strong>Reference:</strong></td>
                                            <td class="text-start"><t t-esc="donation.name"/></td>
                                        </tr>
                                        <tr>
                                            <td class="text-end"><strong>Amount:</strong></td>
                                            <td class="text-start">
                                                <t t-esc="donation.amount" t-options="{'widget': 'monetary', 'display_currency': donation.currency_id}"/>
                                            </td>
                                        </tr>
                                        <tr t-if="donation.campaign_id">
                                            <td class="text-end"><strong>Campaign:</strong></td>
                                            <td class="text-start"><t t-esc="donation.campaign_id.name"/></td>
                                        </tr>
                                        <tr t-if="donation.category_id">
                                            <td class="text-end"><strong>Category:</strong></td>
                                            <td class="text-start"><t t-esc="donation.category_id.name"/></td>
                                        </tr>
                                        <tr t-if="donation.is_recurring">
                                            <td class="text-end"><strong>Schedule:</strong></td>
                                            <td class="text-start">
                                                <t t-if="donation.frequency == 'weekly'">Weekly</t>
                                                <t t-elif="donation.frequency == 'biweekly'">Bi-weekly</t>
                                                <t t-elif="donation.frequency == 'monthly'">Monthly</t>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <div class="mt-4">
                                <t t-if="not request.env.user._is_public()">
                                    <a href="/my/donations" class="btn btn-primary">View My Donations</a>
                                </t>
                                <a href="/" class="btn btn-secondary">Return Home</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
