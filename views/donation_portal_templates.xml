<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Portal: breadcrumbs -->
    <template id="portal_my_home_menu_donations_breadcrumbs" name="Portal layout: donation menu entries" inherit_id="portal.portal_breadcrumbs" priority="35">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'donation'" class="breadcrumb-item active">
                <span>Donations</span>
            </li>
        </xpath>
    </template>

    <!-- Portal: My Account card -->
    <template id="portal_my_home_menu_donations" name="Portal My Home: Donations" customize_show="True" inherit_id="portal.portal_my_home" priority="35">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/donation_management/static/src/img/donation-heart.svg'"/>
                <t t-set="title">Donations</t>
                <t t-set="url" t-value="'/my/donations'"/>
                <t t-set="text">View your donation history and manage recurring donations</t>
                <t t-set="placeholder_count" t-value="'donation_count'"/>
                <t t-set="config_card" t-value="True"/>
            </t>
        </div>
    </template>

    <!-- Portal: My Donations List -->
    <template id="portal_my_donations" name="My Donations">
        <t t-call="portal.portal_layout">
            <t t-set="history_count" t-value="history_count or 0"/>
            <t t-set="history_total_amount" t-value="history_total_amount or 0.0"/>
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Donations</t>
            </t>

            <!-- Recurring Donations (active and paused) -->
            <t t-if="recurring_rules">
                <div class="card o_portal_donation_section mb-4">
                    <div class="card-header o_portal_donation_section_header">
                        <h4 class="mb-0">
                            <i class="fa fa-refresh me-2"></i>Recurring Donations
                        </h4>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 o_portal_donation_table">
                                <thead>
                                    <tr>
                                        <th>Reference</th>
                                        <th>Status</th>
                                        <th>Amount</th>
                                        <th>Frequency</th>
                                        <th>Next Donation</th>
                                        <th>Total Donations</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="recurring_rules" t-as="rule">
                                        <tr>
                                            <td><t t-esc="rule.name"/></td>
                                            <td>
                                                <span t-if="rule.state == 'active'" class="badge rounded-pill text-bg-success">Active</span>
                                                <span t-elif="rule.state == 'paused'" class="badge rounded-pill text-bg-warning">Paused</span>
                                            </td>
                                            <td>
                                                <t t-esc="rule.amount" t-options="{'widget': 'monetary', 'display_currency': rule.currency_id}"/>
                                            </td>
                                            <td>
                                                <t t-if="rule.frequency == 'weekly'">Weekly</t>
                                                <t t-elif="rule.frequency == 'biweekly'">Bi-weekly</t>
                                                <t t-elif="rule.frequency == 'monthly'">Monthly</t>
                                                <t t-else=""><t t-esc="rule.frequency"/></t>
                                            </td>
                                            <td>
                                                <t t-if="rule.state == 'active'">
                                                    <t t-esc="rule.next_donation_date" t-options="{'widget': 'date'}"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-muted">—</span>
                                                </t>
                                            </td>
                                            <td><t t-esc="rule.donation_count"/></td>
                                            <td>
                                                <div class="d-flex flex-wrap gap-1">
                                                    <t t-if="rule.state == 'active'">
                                                        <form method="POST" t-attf-action="/my/recurring_donations/#{rule.id}/pause" class="d-inline">
                                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                            <button type="submit" class="btn btn-sm btn-warning">
                                                                <i class="fa fa-pause"></i> Pause
                                                            </button>
                                                        </form>
                                                    </t>
                                                    <t t-if="rule.state == 'paused'">
                                                        <form method="POST" t-attf-action="/my/recurring_donations/#{rule.id}/resume" class="d-inline">
                                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                            <button type="submit" class="btn btn-sm btn-success">
                                                                <i class="fa fa-play"></i> Resume
                                                            </button>
                                                        </form>
                                                    </t>
                                                    <form method="POST" t-attf-action="/my/recurring_donations/#{rule.id}/cancel" class="d-inline">
                                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                                onclick="return confirm('Cancel this recurring donation permanently? This cannot be undone.');">
                                                            <i class="fa fa-times"></i> Cancel
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                        <p class="text-muted small mb-0 mt-3 o_portal_donation_hint">
                            Paused donations stay listed here so you can resume them anytime. Cancel ends the schedule permanently.
                        </p>
                    </div>
                </div>
            </t>

            <!-- Donation History -->
            <div class="card o_portal_donation_section o_portal_donation_history_card">
                <div class="card-header o_portal_donation_section_header">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <h4 class="mb-0">
                            <i class="fa fa-history me-2"></i>Donation History
                        </h4>
                        <a href="/donate" class="btn btn-primary btn-sm o_portal_donate_btn">
                            <i class="fa fa-plus me-1"></i>Make Another Donation
                        </a>
                    </div>
                </div>
                <form method="get" action="/my/donations" class="o_portal_donation_history_toolbar">
                    <input type="hidden" name="sortby" t-att-value="sortby"/>
                    <div class="o_portal_donation_history_toolbar-inner">
                        <div class="o_portal_donation_history_filters">
                            <div class="o_portal_donation_filter_field">
                                <label class="form-label" for="filter_year">Year</label>
                                <select name="filter_year" id="filter_year" class="form-select form-select-sm">
                                    <option value="" t-att-selected="not filter_year and 'selected' or None">All years</option>
                                    <t t-foreach="available_years" t-as="year">
                                        <option t-att-value="year"
                                                t-att-selected="str(filter_year) == str(year) and 'selected' or None">
                                            <t t-esc="year"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <div class="o_portal_donation_filter_field">
                                <label class="form-label" for="filter_month">Month</label>
                                <select name="filter_month" id="filter_month" class="form-select form-select-sm"
                                        t-att-disabled="not filter_year and 'disabled' or None">
                                    <option value="" t-att-selected="not filter_month and 'selected' or None">All months</option>
                                    <t t-foreach="donation_months" t-as="month_item">
                                        <option t-att-value="month_item[0]"
                                                t-att-selected="str(filter_month) == str(month_item[0]) and 'selected' or None">
                                            <t t-esc="month_item[1]"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <div class="o_portal_donation_filter_actions">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i class="fa fa-filter me-1"/> Apply
                                </button>
                            </div>
                        </div>
                        <div class="o_portal_donation_history_exports">
                            <a t-attf-href="/my/donations/export?sortby={{ sortby }}&amp;filter_year={{ filter_year or '' }}&amp;filter_month={{ filter_month or '' }}&amp;export_format=csv"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="fa fa-download me-1"/> CSV
                            </a>
                            <a t-if="history_count"
                               t-attf-href="/my/donations/export?sortby={{ sortby }}&amp;filter_year={{ filter_year or '' }}&amp;filter_month={{ filter_month or '' }}&amp;export_format=pdf"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="fa fa-file-pdf-o me-1"/> PDF
                            </a>
                        </div>
                    </div>
                    <div class="o_portal_donation_history_summary" t-if="period_label">
                        <span class="o_portal_donation_period_badge">
                            <t t-esc="period_label"/>
                        </span>
                        <span class="text-muted">
                            <t t-esc="history_count"/> donation<t t-if="history_count != 1">s</t>
                        </span>
                    </div>
                </form>
                <div class="card-body pt-0">
                    <t t-if="not has_confirmed_donations">
                        <div class="text-center py-5 o_portal_donation_empty">
                            <i class="fa fa-heart-o o_portal_donation_empty_icon"></i>
                            <p class="mt-3 text-muted">You haven't made any donations yet.</p>
                            <a href="/donate" class="btn btn-primary o_portal_donate_btn">Make Your First Donation</a>
                        </div>
                    </t>
                    <t t-elif="not history_count">
                        <div class="text-center py-5 o_portal_donation_empty">
                            <i class="fa fa-search o_portal_donation_empty_icon text-muted"></i>
                            <p class="mt-3 mb-1 text-muted">No donations match this period.</p>
                            <p class="small text-muted">Try a different year or month, or choose &quot;All years&quot;.</p>
                        </div>
                    </t>
                    <t t-elif="donations">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 o_portal_donation_table">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Reference</th>
                                        <th>Campaign</th>
                                        <th>Amount</th>
                                        <th>Type</th>
                                        <th>Tax Receipt</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="donations" t-as="donation">
                                        <tr>
                                            <td><t t-esc="donation.date" t-options="{'widget': 'date'}"/></td>
                                            <td><t t-esc="donation.name"/></td>
                                            <td>
                                                <t t-if="donation.campaign_id">
                                                    <t t-esc="donation.campaign_id.name"/>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-muted">General</span>
                                                </t>
                                            </td>
                                            <td>
                                                <strong>
                                                    <t t-esc="donation.amount" t-options="{'widget': 'monetary', 'display_currency': donation.currency_id}"/>
                                                </strong>
                                            </td>
                                            <td>
                                                <t t-if="donation.is_recurring">
                                                    <span class="badge bg-info">
                                                        <i class="fa fa-refresh"></i> Recurring
                                                    </span>
                                                </t>
                                                <t t-else="">
                                                    <span class="badge bg-secondary">One-time</span>
                                                </t>
                                            </td>
                                            <td>
                                                <t t-if="donation.tax_receipt_number">
                                                    <span class="text-muted"><t t-esc="donation.tax_receipt_number"/></span>
                                                </t>
                                            </td>
                                            <td class="text-end">
                                                <a t-attf-href="/my/donations/#{donation.id}" class="btn btn-sm btn-outline-primary">
                                                    View
                                                </a>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot t-if="history_count">
                                    <tr class="table-light">
                                        <td colspan="3" class="text-end"><strong>Total Donated:</strong></td>
                                        <td colspan="4">
                                            <strong>
                                                <t t-esc="history_total_amount"
                                                   t-options="{'widget': 'monetary', 'display_currency': history_currency}"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div t-if="pager" class="o_portal_pager text-center">
                            <t t-call="portal.pager"/>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- Portal: Donation Detail -->
    <template id="portal_donation_detail" name="Donation Detail">
        <t t-call="portal.portal_layout">
            <t t-set="o_portal_fullwidth_alert" groups="donation_management.group_donation_manager">
                <t t-call="portal.portal_back_in_edit_mode">
                    <t t-set="backend_url" t-value="'/web#model=donation.donation&amp;id=%s&amp;action=%s&amp;view_type=form' % (donation.id, donation.env.ref('donation_management.action_donation').id)"/>
                </t>
            </t>

            <div class="container mt-4">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="card">
                            <div class="card-header bg-success text-white">
                                <h3 class="mb-0">
                                    <i class="fa fa-heart me-2"></i>Donation Details
                                </h3>
                            </div>
                            <div class="card-body">
                                <div class="row mb-3">
                                    <div class="col-sm-4 text-muted">Reference:</div>
                                    <div class="col-sm-8"><strong><t t-esc="donation.name"/></strong></div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-sm-4 text-muted">Date:</div>
                                    <div class="col-sm-8"><t t-esc="donation.date" t-options="{'widget': 'datetime'}"/></div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-sm-4 text-muted">Amount:</div>
                                    <div class="col-sm-8">
                                        <h4 class="text-success mb-0">
                                            <t t-esc="donation.amount" t-options="{'widget': 'monetary', 'display_currency': donation.currency_id}"/>
                                        </h4>
                                    </div>
                                </div>
                                <t t-if="donation.campaign_id">
                                    <div class="row mb-3">
                                        <div class="col-sm-4 text-muted">Campaign:</div>
                                        <div class="col-sm-8"><t t-esc="donation.campaign_id.name"/></div>
                                    </div>
                                </t>
                                <t t-if="donation.category_id">
                                    <div class="row mb-3">
                                        <div class="col-sm-4 text-muted">Category:</div>
                                        <div class="col-sm-8"><t t-esc="donation.category_id.name"/></div>
                                    </div>
                                </t>
                                <t t-if="donation.is_recurring">
                                    <div class="row mb-3">
                                        <div class="col-sm-4 text-muted">Type:</div>
                                        <div class="col-sm-8">
                                            <span class="badge bg-info">
                                                <i class="fa fa-refresh"></i>
                                                <t t-if="donation.frequency == 'weekly'">Weekly</t>
                                                <t t-elif="donation.frequency == 'biweekly'">Bi-weekly</t>
                                                <t t-elif="donation.frequency == 'monthly'">Monthly</t>
                                                <t t-else="">Recurring</t>
                                            </span>
                                        </div>
                                    </div>
                                </t>
                                <t t-if="donation.purpose">
                                    <div class="row mb-3">
                                        <div class="col-sm-4 text-muted">Purpose/Message:</div>
                                        <div class="col-sm-8"><t t-esc="donation.purpose"/></div>
                                    </div>
                                </t>
                                <t t-if="donation.tax_receipt_number">
                                    <div class="row mb-3">
                                        <div class="col-sm-4 text-muted">Tax Receipt Number:</div>
                                        <div class="col-sm-8"><t t-esc="donation.tax_receipt_number"/></div>
                                    </div>
                                </t>
                                <div class="row mb-3">
                                    <div class="col-sm-4 text-muted">Status:</div>
                                    <div class="col-sm-8">
                                        <span t-attf-class="badge bg-{{ 'success' if donation.state == 'confirmed' else 'warning' }}">
                                            <t t-esc="donation.state.title()"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer text-center">
                                <a href="/my/donations" class="btn btn-secondary">
                                    <i class="fa fa-arrow-left me-1"></i>Back to Donations
                                </a>
                            </div>
                        </div>

                        <!-- Thank You Message -->
                        <div class="alert alert-success mt-4" role="alert">
                            <h4 class="alert-heading">Thank You!</h4>
                            <p class="mb-0">Your generosity makes a real difference. Thank you for your support!</p>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>