<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_provider_form_donation" model="ir.ui.view">
        <field name="name">payment.provider.form.donation</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <field name="allow_tokenization" position="after">
                <field name="donation_fee_coverage_percent"
                       invisible="state == 'disabled'"/>
            </field>
        </field>
    </record>
</odoo>
